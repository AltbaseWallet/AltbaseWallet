{
  "name": "altcoinwallet",
  "productName": "Altbase Wallet",
  "description": "Altbase Wallet",
  "author": "Altbase",
  "homepage": "https://altbase.io",
  "private": true,
  "version": "0.1.6",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "sync:mining": "node scripts/sync-mining-frontend.cjs",
    "build:mining": "node scripts/build-mining-module.cjs",
    "qa:mining-ui": "electron scripts/qa-mining-ui.cjs",
    "release:mining": "node scripts/package-mining-module-release.cjs",
    "dev": "npm run sync:mining && vite",
    "build:zano": "node scripts/build-zano-native.cjs",
    "build:epic": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-epic-resilient.ps1",
    "build:kaspa-wallet-wasm": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-kaspa-wallet-wasm.ps1 -Threads 7",
    "build:core": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-core-native.ps1",
    "build": "npm run sync:mining && npm run build:mining && tsc -b && vite build",
    "build:release": "npm run sync:mining && node scripts/build-mining-module.cjs --require-signature && tsc -b && vite build",
    "cli:build": "vite build --config vite.cli.config.ts",
    "cli": "npm run -s cli:build && node cli-dist/altbase-cli.mjs",
    "electron": "electron .",
    "dist:win": "npm run build:core && npm run dist:win:dir && node scripts/build-native-installer.cjs",
    "dist:win:dir": "npm run build:release && electron-builder --win dir --x64 --config.win.signAndEditExecutable=false && node scripts/set-win-icon.cjs",
    "dist:win:msi": "npm run build:core && npm run dist:win:dir && node scripts/build-native-installer.cjs",
    "dist:win:installer": "npm run dist:win:msi",
    "dist:linux:appimage": "npm run build:release && electron-builder --linux AppImage --x64",
    "dist:linux:dir": "npm run build:release && electron-builder --linux dir --x64",
    "dist:mac:dmg": "npm run build:release && electron-builder --mac dmg --universal",
    "dist:mac:zip": "npm run build:release && electron-builder --mac zip --universal",
    "lint": "eslint .",
    "pretest": "npm run sync:mining && npm run build:mining",
    "test": "node --experimental-strip-types --test tests/**/*.test.ts tests/**/*.test.cjs && node --test modules/mining/dist/tests/*.test.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ckb-ccc/core": "1.16.1",
    "@hookform/resolvers": "^5.2.2",
    "@qubic-lib/qubic-ts-library": "0.1.6",
    "clsx": "^2.1.1",
    "ethers": "6.17.0",
    "framer-motion": "^12.38.0",
    "kaspa-wasm": "file:vendor/kaspa-wasm-v2.0.1",
    "lucide-react": "^1.14.0",
    "qrcode.react": "^4.2.0",
    "quais": "^1.0.0-alpha.54",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.75.0",
    "react-router-dom": "^7.15.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.14",
    "ssh2": "^1.17.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  },
  "build": {
    "appId": "com.altbase.wallet",
    "productName": "Altbase Wallet",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/**/*",
      "logo.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "native-core",
        "to": "native-core"
      },
      {
        "from": "build/icon.ico",
        "to": "build/icon.ico"
      },
      {
        "from": "modules/mining",
        "to": "modules/mining",
        "filter": [
          "module.json",
          "package.json",
          "package.manifest.json",
          "catalog/**/*",
          "docs/**/*",
          "dist/src/**/*",
          "dist/frontend/**/*"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "category": "Finance",
      "icon": "logo.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Altbase-Wallet-Linux-${arch}.${ext}"
    },
    "mac": {
      "category": "public.app-category.finance",
      "minimumSystemVersion": "12.0",
      "extendInfo": {
        "LSArchitecturePriority": [
          "arm64",
          "x86_64"
        ]
      },
      "target": [
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "artifactName": "Altbase-Wallet-macOS-universal.${ext}"
    }
  }
}
