{
  "name": "altcoinwallet",
  "productName": "Altbase Wallet",
  "description": "Altbase Wallet",
  "author": "Altbase",
  "homepage": "https://altbase.io",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build:zano": "node scripts/build-zano-native.cjs",
    "build:epic": "set LIBCLANG_PATH=%APPDATA%\\Python\\Python314\\site-packages\\clang\\native&& set PATH=%USERPROFILE%\\.cargo\\bin;%PATH%&& cargo build --release --manifest-path native/epic_core/Cargo.toml",
    "build:core": "npm run build:zano && npm run build:epic && set GIT_CEILING_DIRECTORIES=%USERPROFILE%\\Desktop&& cmake --preset vs2022-x64-release -S native/core && cmake --build native/core/build/vs2022-x64-release --config Release && node scripts/copy-native-core.cjs",
    "build": "tsc -b && vite build",
    "electron": "electron .",
    "dist:win": "npm run build:core && npm run build && electron-builder --win dir --x64 --config.win.signAndEditExecutable=false && node scripts/set-win-icon.cjs && electron-builder --win nsis --x64 --prepackaged release/win-unpacked --config.win.signAndEditExecutable=false",
    "dist:win:dir": "npm run build && electron-builder --win dir --x64 --config.win.signAndEditExecutable=false && node scripts/set-win-icon.cjs",
    "dist:win:installer": "npm run dist:win",
    "dist:linux:appimage": "npm run build && electron-builder --linux AppImage --x64",
    "dist:linux:dir": "npm run build && electron-builder --linux dir --x64",
    "dist:mac:dmg": "npm run build && electron-builder --mac dmg --x64",
    "dist:mac:zip": "npm run build && electron-builder --mac zip --x64",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "qrcode.react": "^4.2.0",
    "quais": "^1.0.0-alpha.54",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.75.0",
    "react-router-dom": "^7.15.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.14",
    "ssh2": "^1.17.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  },
  "build": {
    "appId": "com.altbase.wallet",
    "productName": "Altbase Wallet",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/**/*",
      "logo.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "native-core",
        "to": "native-core"
      },
      {
        "from": "build/icon.ico",
        "to": "build/icon.ico"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "Altbase-Wallet-Windows.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Altbase Wallet",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "linux": {
      "category": "Finance",
      "icon": "logo.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Altbase-Wallet-Linux-${arch}.${ext}"
    },
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Altbase-Wallet-macOS.${ext}"
    }
  }
}
